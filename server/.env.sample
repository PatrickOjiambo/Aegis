# ─── Runtime ──────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# ─── HTTP API ─────────────────────────────────────────────────────────────
PORT=3000
# Scheme+host the agents advertise in their A2A Agent Cards (no trailing slash)
PUBLIC_HOST=http://localhost

# ─── A2A agent ports ──────────────────────────────────────────────────────
BUYER_A2A_PORT=41241
SELLER_A2A_PORT=41242
ARBITER_A2A_PORT=41243
APPEAL_A2A_PORT=41244

# ─── Database ─────────────────────────────────────────────────────────────
# Single-node replica set provisioned by docker-compose.yml (pnpm mongo:up)
MONGODB_URI=mongodb://localhost:27017/aegis?replicaSet=rs0&directConnection=true

# ─── Casper chain ─────────────────────────────────────────────────────────
# real → live node via casper-js-sdk; mock → deterministic in-memory chain.
# Leave unset to default: real in production, mock otherwise.
CHAIN_MODE=mock
CASPER_NODE_RPC_URL=https://node.testnet.casper.network/rpc
CASPER_NETWORK_NAME=casper-test
# Deployed contract hashes (hex, no "hash-" prefix). Required when CHAIN_MODE=real.
ESCROW_CONTRACT_HASH=
REPUTATION_CONTRACT_HASH=
# Session wasm that performs the payable x402 deposit into escrow.
PROXY_WASM_PATH=../aegis-contracts/target/wasm32-unknown-unknown/release/proxy.wasm

# ─── Signing keys (PEM secret-key files) ──────────────────────────────────
# The arbiter key MUST match the authorized_arbiter set in EscrowVault.init.
ARBITER_SECRET_KEY_PATH=./keys/arbiter_secret_key.pem
BUYER_SECRET_KEY_PATH=./keys/buyer_secret_key.pem
SELLER_SECRET_KEY_PATH=./keys/seller_secret_key.pem

# ─── Arbiter LLM (DeepSeek, OpenAI-compatible) ────────────────────────────
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro
ARBITER_TEMPERATURE=0

# ─── Lifecycle windows / timeouts (milliseconds) ──────────────────────────
REVIEW_WINDOW_MS=259200000
EVIDENCE_WINDOW_MS=86400000
SAFETY_GRACE_MS=3600000
APPEAL_WINDOW_MS=86400000
WORKER_INTERVAL_MS=15000
WORKER_ENABLED=true
AGENTS_ENABLED=true
